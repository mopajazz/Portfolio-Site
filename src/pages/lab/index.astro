---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const lab = (await getCollection('lab')).sort((a,b) => a.data.order - b.data.order);
---
<Base title="Lab — Jamie Warren">
  <section class="band">
    <div class="wrap">
      <p class="eyebrow">The Lab</p>
      <h1>Built for the practice of it</h1>
      <p class="lede">Tools, courses, and experiments. Some ship to thousands of students; some exist because building them was the point.</p>
      <ul class="grid">
        {lab.map(l => (
          <li class="card">
            <h3>{l.data.link ? <a href={l.data.link}>{l.data.title}</a> : l.data.title}</h3>
            <p>{l.data.blurb}</p>
            <span class="meta">{l.data.tags.join(' · ')}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>
