---
import '../styles/global.css';
const { title = 'Jamie Warren', description = 'Instructional designer and developer — SCORM pipelines, Canvas rebuilds, and interactive learning tools.' } = Astro.props;
const path = Astro.url.pathname;
const nav = [
  { href: '/work/', label: 'Work' },
  { href: '/lab/', label: 'Lab' },
  { href: '/about/', label: 'About' },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>
  <a class="skip" href="#main">Skip to content</a>
  <header class="site">
    <div class="wrap">
      <a class="brand" href="/">Jamie Warren</a>
      <nav class="main" aria-label="Primary">
        {nav.map(n => <a href={n.href} aria-current={path.startsWith(n.href) ? 'page' : undefined}>{n.label}</a>)}
      </nav>
    </div>
  </header>
  <main id="main">
    <slot />
  </main>
  <footer class="site">
    <div class="wrap">
      <span>© {new Date().getFullYear()} Jamie Warren · Brevard, NC</span>
      <span>
        <a href="mailto:mopajazz@gmail.com">Email</a> ·
        <a href="https://www.linkedin.com/in/jamie-warren-bb9b2a171/">LinkedIn</a> ·
        <a href="https://jazzinteractive.org">Jazz Interactive</a>
      </span>
    </div>
  </footer>
</body>
</html>
